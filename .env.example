# FinMacroSentinel Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Required Configuration
# ============================================

# Anthropic Claude API Configuration
# Get your API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# Custom API endpoint (leave empty for default)
ANTHROPIC_API_ENDPOINT=

# Feishu App Configuration
# Get credentials from your Feishu open platform
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_CHAT_ID=your_chat_id_here

# ============================================
# Optional Configuration
# ============================================

# Storage
OUTPUT_DIR=./output

# Scheduler Configuration
# Cron expression for scheduled tasks (Beijing timezone)
# Default: 09:00, 12:30, 21:00 on weekdays
# Format: minute hour day month weekday
# Examples:
#   0 9 * * 1-5     - 9:00 on weekdays
#   0 9,12,21 * * 1-5  - 9:00, 12:00, 21:00 on weekdays
#   0 21 * * *      - 21:00 every day
SCHEDULE_CRON=0 9,12,21 * * 1-5

# API Data Sources (Optional)
# FRED API Key - Get from https://fred.stlouisfed.org/apikey
FRED_API_KEY=
# Finnhub API Key - Get from https://finnhub.io/
FINNHUB_API_KEY=

# ============================================
# Docker Deployment
# ============================================
# When using Docker, mount volumes:
#   - ./output:/app/output   (reports output)
#   - ./data:/app/data       (optional data persistence)
#
# Run in scheduled mode:
#   docker-compose up -d
#
# Run once (no scheduling):
#   docker run finmacro-sentinel npm start
#
# View logs:
#   docker-compose logs -f

