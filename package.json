{
  "name": "finmacro-sentinel",
  "version": "1.0.0",
  "description": "Automated financial news analysis and investment decision support system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outdir=dist --external:node_modules --format=cjs --sourcemap",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "finance",
    "macro",
    "hedge-fund",
    "news",
    "analysis",
    "feishu"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.11.16",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
